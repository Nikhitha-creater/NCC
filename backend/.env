# ──────────────────────────────────────────────
# NCC Portal Backend – Environment Variables
# Copy this to .env for local development.
# On Render.com, set these via the dashboard
# (Environment → Add Environment Variable).
# ──────────────────────────────────────────────

# PostgreSQL connection string from Neon/Supabase
# Format: postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_UHaT4WsGMJD8@ep-summer-truth-abseldjj.eu-west-2.aws.neon.tech/neondb?sslmode=require

# Set to "production" on Render
NODE_ENV=development

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://ncc-portal.vercel.app,https://ncc.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# Render assigns PORT automatically; leave this unset in production
# PORT=5000
